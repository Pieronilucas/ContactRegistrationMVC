@using System.Text.RegularExpressions
@model List<UsuarioModel>
@{
    ViewData["Title"] = "Lista de usuários";
}
<div class="text-center">
    
    <div class="d-grid gap-2 d-md-flex justfy-content-md-start">
        <a class="btn btn-info" role="button" asp-controller="Usuario" asp-action="Create">Adicionar novo Usuário</a>
    </div>
    
    <br>

    
    @if (TempData["SucessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-secondary btn-sm close-alert" aria-label="Close">X</button>
            @TempData["SucessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" aria-label="Close">X</button>
            @TempData["ErrorMessage"]
        </div>
    }
    
    <h1 class="display-4">Lista de usuários</h1>

    <table class="table table-striped" id="table-usuarios">
        <thead>
        <tr>
            <th scope="col">ID</th>
            <th scope="col">Nome</th>
            <th scope="col">E-mail</th>
            <th scope="col">Login</th>
            <th scope="col">Data de cadastro</th>
            <th scope="col"></th>
        </tr>
        </thead>
        <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (UsuarioModel usuario in Model)
            {
                <tr>
                    <th scope="row">@usuario.Id</th>
                    <td>@usuario.Nome</td>
                    <td>@usuario.Email</td>
                    <td>@usuario.Login</td>
                    <td>@usuario.CriadoEm</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a role="button" class="btn btn-primary" asp-route-id="@usuario.Id" asp-controller="Usuario" asp-action="Edit">Editar</a>
                            <a role="button" class="btn btn-danger" asp-route-id="@usuario.Id" asp-controller="Usuario" asp-action="DeleteConfirmation">Apagar</a>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">Nenhum usuário cadastrado</td>
            </tr>
        } 
        </tbody>
    </table>
</div>

