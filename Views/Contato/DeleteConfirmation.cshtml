@{
    ViewData["Title"] = "Confirmação de exclusão";
}

<div class="text-center">
    
    <h3>Realmente deseja apagar o contato (Insira o nome do contato)?</h3>
    
</div>

<a class="btn btn-danger d-block w-100 mb-3" role="button" asp-controller="Contato" asp-action="Delete">Confirmar exclusão</a>
<a class="btn btn-primary d-block w-100 mb-3" role="button" asp-controller="Contato" asp-action="Index">Cancelar exclusão</a>
