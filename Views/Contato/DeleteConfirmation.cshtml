@model ContatoModel
@{
    ViewData["Title"] = "Confirmação de exclusão";
}

<input type="hidden" asp-for="Id"/>
<div class="text-center">

    <h3>Realmente deseja apagar o contato (@Model.Nome)?</h3>
    
</div>

<a class="btn btn-danger d-block w-100 mb-3" role="button" asp-controller="Contato" asp-route-id="@Model.Id" asp-action="Delete">Confirmar exclusão</a>
<a class="btn btn-primary d-block w-100 mb-3" role="button" asp-controller="Contato" asp-action="Index">Cancelar exclusão</a>
